# Compilatore e flag
CC = gcc
CFLAGS = -Iinclude -Wall -Wextra -Werror -g
BIN = bin
OBJ = obj
SRC = src
INCLUDE = include
OBJS = $(patsubst $(SRC)/%.c, $(OBJ)/%.o, $(wildcard $(SRC)/*.c))

# Regola principale per creare l'eseguibile
all: $(BIN)/main

# Regola per creare l'eseguibile
$(BIN)/main: $(OBJS) 
	$(CC) $(CFLAGS) $^ -o $@

# Regola per creare i file oggetto
$(OBJ)/%.o: $(SRC)/%.c 
	$(CC) $(CFLAGS) -c $< -o $@

# Pulizia dei file oggetto e degli eseguibili
clean:
	rm -f $(OBJ)/*.o $(BIN)/*.exe $(BIN)/*

# Pulizia completa dei file oggetto e degli eseguibili (senza cancellare i .c)
clean-all:	
	rm -f $(OBJ)/*.o $(BIN)/*.exe $(BIN)/* $(BIN)/main

.PHONY: all clean clean-all